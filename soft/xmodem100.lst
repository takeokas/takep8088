     1                                  ;--------------------------------------
     2                                  ; XMODEM Receive loader (Checksum)
     3                                  ;受信開始時に NAK を送信
     4                                  ;SOH を受信 → 128バイト受信
     5                                  ;チェックサム確認
     6                                  ;OK → ACK / NG → NAK
     7                                  ;EOT を受信したら ACK を返して終了
     8                                  ;受信データは 000400h に格納
     9                                  ;--------------------------------------
    10                                  ; takep8088
    11                                  USARTD	equ	00h	;8251 data register
    12                                  USARTC	equ	01h	;8251 control register
    13                                  ;
    14                                  stack_seg	equ 02000h
    15                                  stack		equ 0fffeh ; 0FFFFから前へ
    16                                  ;
    17                                  	;; Xmodem constants
    18                                  SOH equ 01h
    19                                  EOT equ 04h
    20                                  ACK equ 06h
    21                                  NAK equ 15h
    22                                  CAN equ 18h
    23                                  ;
    24                                  ;
    25                                  ;;;  loaded bin top= 00400h, 
    26                                  recv_objseg equ 040h	;recv obj from 00400h
    27                                  ;recv_objoff equ 000h
    28                                  recv_objoff equ 100h
    29                                  ;
    30                                  block_no equ 0fff0h		;0400h+fff0h
    31                                  ;
    32                                  ;;; 
    33                                  ;;; 0FFF00h
    34                                  	section .text
    35                                  	;org 0ff00h
    36                                  start_off equ 0ff00h
    37 00000000 FF<rep FF00h>           	TIMES start_off-($-$$) DB 0FFh
    38                                  ;;; 
    39                                  start:	
    40                                  	;;; stack<= 02000h 
    41 0000FF00 B80020                  	mov ax,stack_seg
    42 0000FF03 8ED0                    	mov ss,ax
    43 0000FF05 BCFEFF                  	mov sp,stack
    44                                  	;
    45                                  	;mov ax,data_seg
    46                                  	;mov ds,ax
    47                                  	;mov es,ax
    48                                  	;
    49                                  	;
    50                                  ;	8251 setup
    51 0000FF08 BA0100                  	mov	dx,USARTC
    52 0000FF0B B000                    	mov	al,00h	;Default mode or no operation
    53 0000FF0D EE                      	out	dx,al	;Try command
    54 0000FF0E EE                      	out	dx,al	;Try command
    55 0000FF0F EE                      	out	dx,al	;Try command
    56 0000FF10 B040                    	mov	al,40h	;reset
    57 0000FF12 EE                      	out	dx,al	;Out it
    58 0000FF13 B91000                  	mov	CX,16	;Delay
    59 0000FF16 E2FE                    	loop	$	;Delay
    60 0000FF18 B04E                    	mov	al,4eh	;mode
    61 0000FF1A EE                      	out	dx,al	;Out it
    62 0000FF1B B037                    	mov	al,37h	;command
    63 0000FF1D EE                      	out	dx,al	;Out it
    64                                  	;; end of 8251 setup
    65 0000FF1E B023                    	mov al,"#"
    66 0000FF20 E87500                  	call putc
    67                                  ;
    68                                  xmodem_start:
    69 0000FF23 B84000                      mov ax,recv_objseg
    70 0000FF26 8ED8                        mov ds,ax
    71 0000FF28 8EC0                        mov es,ax
    72                                      ;
    73                                      ;mov al,1
    74                                      ;mov [block_no], al
    75 0000FF2A C606F0FF01                  mov byte [block_no], 1
    76                                  	;; 
    77 0000FF2F E86200                      call send_nak    ; 最初の NAK
    78 0000FF32 BF0001                      mov di,recv_objoff
    79                                  	;; 
    80                                  main_loop:
    81 0000FF35 E86B00                      call getc
    82 0000FF38 3C01                        cmp al, SOH
    83 0000FF3A 7406                        je recv_block
    84 0000FF3C 3C04                        cmp al, EOT
    85 0000FF3E 743A                        je recv_eot
    86 0000FF40 EBF3                        jmp main_loop
    87                                  
    88                                  ;--------------------------
    89                                  ; 128バイトブロック受信
    90                                  ;--------------------------
    91                                  recv_block:
    92 0000FF42 E85E00                      call getc         ; block number
    93 0000FF45 88C3                        mov bl, al
    94                                      ;
    95 0000FF47 E85900                      call getc         ; inverted block number
    96 0000FF4A F6D0                        not al
    97 0000FF4C 38D8                        cmp al, bl
    98 0000FF4E 7525                        jne block_error
    99                                      ;
   100 0000FF50 3A1EF0FF                    cmp bl, [block_no]
   101 0000FF54 751F                        jne block_error
   102                                      ; データ受信
   103 0000FF56 B98000                      mov cx, 128
   104 0000FF59 30F6                        xor dh, dh             ; checksum=0
   105                                      ;
   106                                  recv_data:
   107 0000FF5B E84500                      call getc
   108 0000FF5E 8805                        mov [di], al
   109 0000FF60 00C6                        add dh, al ; checksum +=al
   110 0000FF62 47                          inc di
   111 0000FF63 E2F6                        loop recv_data
   112                                      ;
   113 0000FF65 E83B00                      call getc	;recv checksum
   114 0000FF68 38F0                        cmp al, dh    ; check チェックサム    
   115 0000FF6A 7509                        jne block_error
   116                                      ; OK
   117 0000FF6C E82100                      call send_ack
   118 0000FF6F FE06F0FF                    inc byte [block_no]
   119 0000FF73 EBC0                        jmp main_loop
   120                                  	;;
   121                                  block_error:
   122 0000FF75 E81C00                      call send_nak
   123 0000FF78 EBBB                        jmp main_loop
   124                                  
   125                                  ;--------------------------
   126                                  ; EOT処理 & jump to loaded Obj
   127                                  ;--------------------------
   128                                  recv_eot:
   129 0000FF7A E81300                  	call send_ack
   130                                  	;; display hex dump
   131 0000FF7D BF0004                  	mov di,0400h		; 00400 番地から
   132 0000FF80 B96400                  	mov cx,100
   133                                  ld01:	
   134 0000FF83 8A05                    	MOV  al,[DI]
   135 0000FF85 E82C00                  	call hex
   136 0000FF88 47                      	INC  DI
   137 0000FF89 E2F8                    	LOOP  ld01
   138                                  	;; jump to loaded obj
   139 0000FF8B EA00014000              	jmp  recv_objseg:recv_objoff ;db 0eah ;jmp far, offset, segment; start=400h{cs=40h,pc=100h}
   140                                  	;jmp  040h:0h ;db 0eah ;jmp far, offset, segment; start=400h{cs=40h,pc=00h}
   141                                  	;jmp  040h:100h ;db 0eah ;jmp far, offset, segment; start=400h{cs=40h,pc=100h}
   142                                  	;; 
   143                                  ;;; 
   144                                  send_ack:
   145 0000FF90 B006                        mov al, ACK
   146 0000FF92 EB04                        jmp putc
   147                                  
   148                                  send_nak:
   149 0000FF94 B015                        mov al, NAK
   150 0000FF96 EB00                        jmp putc
   151                                  
   152                                  ;--------------------------
   153                                  ; Serial I/O
   154                                  ;--------------------------
   155                                  send_char:
   156 0000FF98 50                      putc:	push ax
   157 0000FF99 E401                    putc1:	in	al,USARTC	;Get status
   158 0000FF9B 2401                    	and	al,01h		;check TxBUF empty
   159 0000FF9D 74FA                    	jz	putc1		;wait for empty
   160 0000FF9F 58                      	pop	ax		;Restore char
   161 0000FFA0 E600                    	out	USARTD,al	;Out it
   162 0000FFA2 C3                      	ret
   163                                  	;; end of putc
   164                                  
   165                                  recv_char:
   166                                  getc:	
   167                                  getc1:
   168                                  	;;; himatubusi SW->LED
   169 0000FFA3 E404                    	in al,04h		;read SW1
   170 0000FFA5 00C0                    	add al,al
   171 0000FFA7 00C0                    	add al,al
   172 0000FFA9 E60C                    	out 0Ch,al		;out LED
   173                                  	;;; 
   174 0000FFAB E401                    	in	al,USARTC	;Get status
   175 0000FFAD 2402                    	and	al,02h		;check RxBUF full
   176 0000FFAF 74F2                    	jz	getc1		;wait for empty
   177 0000FFB1 E400                    	in	al,USARTD	;Get Char
   178 0000FFB3 C3                      	ret
   179                                  	;; end of getc
   180                                  ;;; 
   181                                  hex:
   182 0000FFB4 50                      	push ax
   183                                  	;shr al,4
   184 0000FFB5 D0E8                    	shr al,1
   185 0000FFB7 D0E8                    	shr al,1
   186 0000FFB9 D0E8                    	shr al,1
   187 0000FFBB D0E8                    	shr al,1
   188 0000FFBD E80100                  	call hexlo
   189 0000FFC0 58                      	pop ax
   190                                  hexlo:
   191 0000FFC1 240F                    	and al,0Fh
   192 0000FFC3 0490                    	add al, 90h
   193 0000FFC5 27                      	daa
   194 0000FFC6 1440                    	adc al, 40h
   195 0000FFC8 27                      	daa
   196                                  	;jmp putc
   197 0000FFC9 E8CCFF                  	call putc
   198 0000FFCC C3                      	ret
   199                                  ;;; 
   200                                  
   201                                  ;;;
   202                                  ;;;
   203                                  ;;;
   204                                  	; Reset  at FFFF0h
   205                                  	;section .text
   206                                          ;org     0fff0h		;offset
   207                                  reset_off equ 0fff0h
   208 0000FFCD FF<rep 23h>             	TIMES reset_off-($-$$) DB 0FFh
   209                                  	;
   210 0000FFF0 EA                              db      0eah    ;jmp far
   211 0000FFF1 [00FF]                          dw      start   ;offset
   212 0000FFF3 00F0                            dw      0F000h   ;segment
   213                                                          ;
   214                                  
   215                                  ;--------------------------
   216                                  ; Data Area
   217                                  ;--------------------------
   218                                  ;block_no:	db 1
   219                                  ;buffer:	db 128 dup (0)
   220                                  
   221                                  ;end
